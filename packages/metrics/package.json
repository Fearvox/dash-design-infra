    ".": "./src/index.ts",
    "./css": "./build/metrics.css"
  },
  "scripts": {
    "extract": "bun run src/extract.ts",
    "build": "bun run src/build-css.ts",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@capsizecss/core": "^4.1.2",
    "@capsizecss/metrics": "^3.4.0"
  }
}
