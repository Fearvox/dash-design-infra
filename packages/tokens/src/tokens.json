{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "DASH Design System tokens — single source of truth. Mirrors colors_and_type.css v0.2.0 (2026-04-17). Any change here must be accompanied by an update to the CSS file until the two are fully unified via style-dictionary build output.",

  "color": {
    "paper": {
      "base":    { "$value": "oklch(0.96 0.01 85)",   "$type": "color", "$description": "Page background" },
      "grain":   { "$value": "oklch(0.93 0.015 80)",  "$type": "color", "$description": "Subtle texture layer" },
      "shadow":  { "$value": "oklch(0.88 0.02 75)",   "$type": "color", "$description": "Dividers, borders" },
      "card":    { "$value": "oklch(0.94 0.012 83)",  "$type": "color", "$description": "Card background" },
      "warm":    { "$value": "#ddd6c7",               "$type": "color", "$description": "DASH wordmark on dark" }
    },

    "ink": {
      "primary":   { "$value": "oklch(0.22 0.02 60)",   "$type": "color", "$description": "Body + headings" },
      "secondary": { "$value": "oklch(0.45 0.02 65)",   "$type": "color", "$description": "Supporting text" },
      "muted":     { "$value": "oklch(0.62 0.015 70)",  "$type": "color", "$description": "Kickers, meta labels" }
    },

    "accent": {
      "palmShadow": { "$value": "oklch(0.35 0.08 160)", "$type": "color", "$description": "Primary accent — deep palm green" },
      "palmLight":  { "$value": "oklch(0.55 0.10 145)", "$type": "color", "$description": "Hover / variant" },
      "sunGold":    { "$value": "oklch(0.82 0.12 85)",  "$type": "color", "$description": "Highlight underline" },
      "dangerRed":  { "$value": "oklch(0.55 0.18 25)",  "$type": "color", "$description": "Fabricated / error state" },
      "hoverGlow":  { "$value": "oklch(0.90 0.06 85)",  "$type": "color", "$description": "Hover state" }
    },

    "botanical": {
      "ink":  { "$value": "#10291F", "$type": "color", "$description": "Logo primary / dark bg" },
      "deep": { "$value": "#0a0f0d", "$type": "color", "$description": "True dark surface" },
      "mid":  { "$value": "#35584C", "$type": "color", "$description": "Logo on light / secondary" },
      "leaf": { "$value": "#7ed29a", "$type": "color", "$description": "Dark-mode accent per PERSONA" },
      "neonGold": { "$value": "#F0EE9B", "$type": "color", "$description": "Neon mark — sparingly" }
    },

    "badge": {
      "minimax": { "$value": "oklch(0.35 0.08 160)", "$type": "color" },
      "opus":    { "$value": "oklch(0.40 0.08 70)",  "$type": "color" },
      "grok":    { "$value": "oklch(0.45 0.14 25)",  "$type": "color" },
      "gemini":  { "$value": "oklch(0.40 0.12 260)", "$type": "color" },
      "gpt":     { "$value": "oklch(0.35 0.10 170)", "$type": "color" }
    },

    "rule": {
      "default": { "$value": "oklch(0.22 0.02 60 / 0.18)", "$type": "color" },
      "soft":    { "$value": "oklch(0.22 0.02 60 / 0.10)", "$type": "color" }
    }
  },

  "font": {
    "family": {
      "sans": {
        "$value": ["Geist", "system-ui", "-apple-system", "sans-serif"],
        "$type": "fontFamily"
      },
      "mono": {
        "$value": ["Geist Mono", "ui-monospace", "SF Mono", "Menlo", "monospace"],
        "$type": "fontFamily"
      }
    },

    "size": {
      "$description": "5-step type scale — ratio ≈ φ between adjacent. Seeded from the original fixed-canvas reference CSS. @dash/scale can replace these with generated values in a later pass.",
      "display": { "$value": "46px",   "$type": "dimension", "$description": "h1 titles" },
      "deck":    { "$value": "22px",   "$type": "dimension", "$description": "Primary findings, r-name" },
      "body":    { "$value": "14px",   "$type": "dimension", "$description": "r-body, prompts" },
      "meta":    { "$value": "11px",   "$type": "dimension", "$description": "Kickers, labels, owner" },
      "micro":   { "$value": "9.5px",  "$type": "dimension", "$description": "Run tags, tiny mono" }
    },

    "lineHeight": {
      "$description": "All values are 8px-baseline-snapped multiples (@dash/metrics capsize will enforce character-level placement).",
      "tight":  { "$value": "16px", "$type": "dimension", "$description": "2 × baseline — micro/meta/body-meta" },
      "base":   { "$value": "24px", "$type": "dimension", "$description": "3 × baseline — body/ph" },
      "loose":  { "$value": "32px", "$type": "dimension", "$description": "4 × baseline — deck/headings" },
      "display":{ "$value": "48px", "$type": "dimension", "$description": "6 × baseline — display title" }
    }
  },

  "baseline": {
    "$value": "8px",
    "$type": "dimension",
    "$description": "8px baseline — all vertical rhythm must be a multiple of this."
  },

  "space": {
    "$description": "Spacing tokens — all multiples of 4px. Default ladder 4/8/12/16/20/24/32/48/64/80.",
    "1":  { "$value": "4px",  "$type": "dimension" },
    "2":  { "$value": "8px",  "$type": "dimension" },
    "3":  { "$value": "12px", "$type": "dimension" },
    "4":  { "$value": "16px", "$type": "dimension" },
    "5":  { "$value": "20px", "$type": "dimension" },
    "6":  { "$value": "24px", "$type": "dimension" },
    "7":  { "$value": "32px", "$type": "dimension" },
    "8":  { "$value": "48px", "$type": "dimension" },
    "9":  { "$value": "64px", "$type": "dimension" },
    "10": { "$value": "80px", "$type": "dimension" }
  },

  "page": {
    "$description": "Landscape one-pager canvas. A-series √2:1 reverse-beat (spec § 8.3).",
    "width":   { "$value": "1684px", "$type": "dimension" },
    "height":  { "$value": "1191px", "$type": "dimension" },
    "padding": { "$value": "66px",   "$type": "dimension", "$description": "Applied asymmetrically: padTop = 0.72 × padding (optical balance)." },
    "gap":     { "$value": "48px",   "$type": "dimension", "$description": "Major rhythm — 6 × baseline." },
    "gridColumns": { "$value": 12, "$type": "number" },
    "gridGap":     { "$value": "24px", "$type": "dimension" }
  },

  "radius": {
    "sm":   { "$value": "3px",   "$type": "dimension", "$description": "Badges" },
    "md":   { "$value": "4px",   "$type": "dimension", "$description": "Inputs, buttons" },
    "lg":   { "$value": "6px",   "$type": "dimension", "$description": "Cards, tables" },
    "pill": { "$value": "999px", "$type": "dimension", "$description": "Avatars, pills" }
  },

  "motion": {
    "ease": {
      "entrance": { "$value": "cubic-bezier(0.22, 1, 0.36, 1)", "$type": "cubicBezier" },
      "bounce":   { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" }
    },
    "duration": {
      "fast":   { "$value": "150ms", "$type": "duration" },
      "base":   { "$value": "280ms", "$type": "duration" },
      "reveal": { "$value": "600ms", "$type": "duration" },
      "max":    { "$value": "750ms", "$type": "duration" }
    }
  }
}
