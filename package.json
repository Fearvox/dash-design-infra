{
  "name": "dash-design-infra",
  "version": "0.0.1",
  "private": true,
  "description": "Fixed-canvas editorial design infrastructure on Bun: tokens, type scale, baseline metrics, layout, and print.",
  "license": "MIT",
  "homepage": "https://github.com/Fearvox/dash-design-infra",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fearvox/dash-design-infra.git"
  },
  "bugs": {
    "url": "https://github.com/Fearvox/dash-design-infra/issues"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "editorial",
    "fixed-canvas",
    "print-css",
    "pagedjs",
    "playwright",
    "bun",
    "typescript"
  ],
  "engines": {
    "bun": ">=1.3",
    "node": ">=20"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "typecheck": "bun run --filter='*' typecheck",
    "clean": "rm -rf packages/*/build packages/*/dist packages/*/node_modules node_modules",
    "tokens:build": "bun run --filter=@dash/tokens build",
    "scale:gen": "bun run --filter=@dash/scale gen",
    "metrics:build": "bun run --filter=@dash/metrics build",
    "metrics:extract": "bun run --filter=@dash/metrics extract",
    "measure:check": "bun run --filter=@dash/measure check",
    "print:render": "bun run --filter=@dash/print render"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "@types/bun": "^1.1.13"
  }
}
