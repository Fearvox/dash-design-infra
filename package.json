{
  "name": "dash-design-infra",
  "version": "0.0.1",
  "private": true,
  "description": "Fixed-canvas editorial design infrastructure on Bun: tokens, type scale, baseline metrics, Kami presets, p5 motion, layout, and print.",
  "license": "MIT",
  "homepage": "https://github.com/Fearvox/dash-design-infra",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fearvox/dash-design-infra.git"
  },
  "bugs": {
    "url": "https://github.com/Fearvox/dash-design-infra/issues"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "editorial",
    "fixed-canvas",
    "print-css",
    "p5js",
    "creative-coding",
    "motion-design",
    "kami",
    "pagedjs",
    "playwright",
    "bun",
    "typescript"
  ],
  "engines": {
    "bun": ">=1.3",
    "node": ">=20"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "typecheck": "bun run --filter='*' typecheck",
    "clean": "rm -rf packages/*/build packages/*/dist packages/*/node_modules node_modules",
    "tokens:build": "bun run --filter=@dash/tokens build",
    "scale:gen": "bun run --filter=@dash/scale gen",
    "metrics:build": "bun run --filter=@dash/metrics build",
    "metrics:extract": "bun run --filter=@dash/metrics extract",
    "measure:check": "bun packages/measure/src/cli.ts",
    "print:render": "bun packages/print/src/cli.ts",
    "docs:links": "bun scripts/markdown-link-check.ts",
    "security:scan": "bun scripts/public-boundary-scan.ts",
    "creator:capsule-check": "bun scripts/creator-capsule-check.ts",
    "creator:evolution-check": "bun scripts/creator-evolution-check.ts",
    "creator:mutation-check": "bun scripts/creator-mutation-check.ts",
    "creator:poster-check": "bun scripts/creator-poster-check.ts",
    "creator:prompt-dna-check": "bun scripts/creator-prompt-dna-check.ts",
    "hackathon:score": "bun scripts/hackathon-score.ts"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "@types/bun": "^1.1.13"
  }
}
