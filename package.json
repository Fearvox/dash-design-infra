{
  "name": "dash-design-infra",
  "version": "0.0.1",
  "private": true,
  "description": "Fixed-canvas editorial design infrastructure on Bun: tokens, type scale, baseline metrics, Kami presets, p5 motion, layout, and print.",
  "license": "MIT",
  "homepage": "https://github.com/Fearvox/dash-design-infra",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Fearvox/dash-design-infra.git"
  },
  "bugs": {
    "url": "https://github.com/Fearvox/dash-design-infra/issues"
  },
  "keywords": [
    "design-system",
    "design-tokens",
    "editorial",
    "fixed-canvas",
    "print-css",
    "p5js",
    "creative-coding",
    "motion-design",
    "kami",
    "pagedjs",
    "playwright",
    "bun",
    "typescript"
  ],
  "engines": {
    "bun": ">=1.3",
    "node": ">=20"
  },
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "build": "bun run --filter='*' build",
    "typecheck": "bun run --filter='*' typecheck",
    "clean": "rm -rf packages/*/build packages/*/dist packages/*/node_modules node_modules",
    "tokens:build": "bun run --filter=@dash/tokens build",
    "scale:gen": "bun run --filter=@dash/scale gen",
    "metrics:build": "bun run --filter=@dash/metrics build",
    "metrics:extract": "bun run --filter=@dash/metrics extract",
    "measure:check": "bun packages/measure/src/cli.ts",
    "print:render": "bun packages/print/src/cli.ts",
    "p5:motion-check": "bun scripts/p5-motion-check.ts",
    "docs:links": "bun scripts/markdown-link-check.ts",
    "security:scan": "bun scripts/public-boundary-scan.ts",
    "creator:capsule-check": "bun scripts/creator-capsule-check.ts",
    "creator:evolution-check": "bun scripts/creator-evolution-check.ts",
    "creator:mutation-check": "bun scripts/creator-mutation-check.ts",
    "creator:poster-check": "bun scripts/creator-poster-check.ts",
    "creator:prompt-dna-check": "bun scripts/creator-prompt-dna-check.ts",
    "hackathon:score": "bun scripts/hackathon-score.ts",
    "creator:motion-storyboard-check": "bun scripts/creator-motion-storyboard-check.ts",
    "creator:contact-sheet-check": "bun scripts/creator-contact-sheet-check.ts",
    "creator:social-card-check": "bun scripts/creator-social-card-check.ts",
    "creator:pdf-zine-check": "bun scripts/creator-pdf-zine-check.ts",
    "creator:p5-sketch-check": "bun scripts/creator-p5-sketch-check.ts",
    "creator:remotion-scene-check": "bun scripts/creator-remotion-scene-check.ts",
    "creator:manim-scene-check": "bun scripts/creator-manim-scene-check.ts",
    "creator:touchdesigner-tox-check": "bun scripts/creator-touchdesigner-tox-check.ts",
    "creator:browser-demo-check": "bun scripts/creator-browser-demo-check.ts",
    "creator:skill-package-check": "bun scripts/creator-skill-package-check.ts",
    "creator:multi-surface-proof": "bun scripts/creator-multi-surface-proof.ts",
    "creator:darwin-autonomy-check": "bun scripts/creator-darwin-autonomy-check.ts",
    "creator:docs-surface-parity": "bun scripts/creator-docs-surface-parity.ts",
    "creator:regression": "bun scripts/creator-regression-check.ts",
    "daemon:start": "bun run --filter=@dash/daemon start",
    "daemon:dev": "bun run --filter=@dash/daemon dev"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "@types/node": "^22.9.0",
    "@types/bun": "^1.1.13"
  }
}
